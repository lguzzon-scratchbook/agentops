# .agents/schedule.yaml — AgentOps continuous knowledge worker schedule
#
# This is an OPT-IN starter. Copy to .agents/schedule.yaml to activate, OR run:
#   ao init --with-schedule
#
# Then start the daemon with:
#   ao daemon run --workers 2 --schedule-file .agents/schedule.yaml
#
# Job types in this starter use REAL-BODIED executors (dream.run + wiki.forge).
# llmwiki.loop is intentionally excluded — its stage handlers are stubs in v1.0;
# wait for the real-bodies follow-up before scheduling.
#
# See docs/contracts/agentopsd-schedule.md for the full schema reference,
# cron expression cheat-sheet, backpressure semantics, and operator runtime
# templates (launchd / systemd-user).

schedules:
  - name: nightly-dream
    cron: "0 3 * * *"
    job_type: dream.run
    payload:
      output_dir: ".agents/overnight"
      max_iterations: 5
      execution_timeout: "4h"
      goal: "Nightly knowledge consolidation"
    timeout: "4h30m"
    backpressure:
      skip_if_running: true
      max_queue_depth: 1

  - name: hourly-forge
    cron: "5 * * * *"
    job_type: wiki.forge
    payload:
      tier: "forge-transcript"
      source_paths:
        - ".agents/sessions/"
      worker_kind: "claude"
      provider: "anthropic"
      model: "claude-sonnet-4"
    backpressure:
      skip_if_running: false
      max_queue_depth: 5
