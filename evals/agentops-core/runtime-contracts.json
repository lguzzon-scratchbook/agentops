{
  "schema_version": 1,
  "id": "agentops-core.runtime-contracts",
  "name": "AgentOps Runtime Contracts Canary",
  "description": "Offline public canary for live runtime adapter hygiene, Codex lifecycle command docs, Codex skill guards, and focused mocked runtime tests.",
  "domain": "runtime",
  "visibility": "public_canary",
  "tier": "deterministic",
  "owners": ["agentops"],
  "tags": ["canary", "offline", "runtime", "codex", "claude"],
  "allowed_runtimes": ["static", "shell"],
  "environment": {
    "offline_required": true,
    "network": "forbidden",
    "scrub_env_prefixes": ["AGENTOPS_RPI_RUNTIME", "ANTHROPIC_", "OPENAI_"],
    "timeout_seconds": 90
  },
  "scoring": {
    "aggregate_threshold": 1,
    "dimensions": [
      {"name": "correctness", "weight": 2, "threshold": 1, "critical": true},
      {"name": "process_adherence", "weight": 1, "threshold": 1},
      {"name": "artifact_quality", "weight": 1, "threshold": 1},
      {"name": "runtime_compatibility", "weight": 2, "threshold": 1, "critical": true},
      {"name": "safety", "weight": 1, "threshold": 1, "critical": true}
    ]
  },
  "baseline_policy": {"mode": "compare", "baseline_path": ".agents/evals/baselines/agentops-core.runtime-contracts.baseline.json", "blocking_gate": "none"},
  "cases": [
    {
      "id": "runtime-isolation-contract",
      "title": "runtime isolation contract captures hygiene requirements",
      "kind": "artifact_check",
      "objective": "Protect the documented runtime safety contract for headless and live eval tiers.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "isolated `CODEX_HOME`"},
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "scrub every `AGENTOPS_RPI_RUNTIME*` environment variable"},
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "status: skipped"},
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "`runtime_compatibility`"}
      ],
      "dimensions": ["runtime_compatibility", "safety", "artifact_quality"],
      "critical": true
    },
    {
      "id": "live-runtime-adapter-source",
      "title": "live runtime adapter source preserves skip and hygiene paths",
      "kind": "artifact_check",
      "objective": "Ensure optional Claude/Codex runtime adapters stay opt-in, skip unavailable tools, and scrub runtime state.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../cli/internal/eval/runtime.go", "value": "Callers must set Enabled=true before any external Claude/Codex process is run"},
        {"type": "artifact_contains", "target": "../../cli/internal/eval/runtime.go", "value": "markRuntimeSkipped(record, suite, \"live runtime disabled; set LiveRuntimeOptions.Enabled to true\")"},
        {"type": "artifact_contains", "target": "../../cli/internal/eval/runtime.go", "value": "case RuntimeClaude:"},
        {"type": "artifact_contains", "target": "../../cli/internal/eval/runtime.go", "value": "case RuntimeCodex:"},
        {"type": "artifact_contains", "target": "../../cli/internal/eval/runtime.go", "value": "CODEX_HOME isolated"},
        {"type": "artifact_contains", "target": "../../cli/internal/eval/runtime.go", "value": "\"AGENTOPS_RPI_RUNTIME\", \"CLAUDECODE\", \"CLAUDE_CODE_\""}
      ],
      "dimensions": ["correctness", "runtime_compatibility", "safety"],
      "critical": true
    },
    {
      "id": "runtime-adapter-focused-tests",
      "title": "mocked live runtime adapter tests pass",
      "kind": "command",
      "objective": "Exercise runtime skip, opt-in, isolation, artifact capture, and error behavior without launching live Claude or Codex.",
      "runtime": "shell",
      "inputs": {
        "cwd": "../../cli",
        "shell": "env -u AGENTOPS_RPI_RUNTIME go test -timeout=120s ./internal/eval -run 'TestRunLiveRuntime(SkipsWhenExecutableUnavailable|DisabledSkipsBeforeExternalProbe|IsolatesAndScrubsCodexEnvironment|CapturesTranscriptAndScorecardArtifacts|PropagatesRunnerErrors)'"
      },
      "expectations": [
        {"type": "exit_code", "value": 0}
      ],
      "dimensions": ["correctness", "runtime_compatibility", "safety"],
      "critical": true
    },
    {
      "id": "codex-lifecycle-cli-docs",
      "title": "codex lifecycle and runtime command docs remain visible",
      "kind": "artifact_check",
      "objective": "Keep generated CLI docs aligned with Codex hookless lifecycle commands and runtime command selection.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../cli/docs/COMMANDS.md", "value": "#### `ao codex ensure-start`"},
        {"type": "artifact_contains", "target": "../../cli/docs/COMMANDS.md", "value": "#### `ao codex ensure-stop`"},
        {"type": "artifact_contains", "target": "../../cli/docs/COMMANDS.md", "value": "ao codex ensure-start [flags]"},
        {"type": "artifact_contains", "target": "../../cli/docs/COMMANDS.md", "value": "ao codex ensure-stop [flags]"},
        {"type": "artifact_contains", "target": "../../cli/docs/COMMANDS.md", "value": "Codex uses 'exec'"}
      ],
      "dimensions": ["artifact_quality", "process_adherence", "runtime_compatibility"]
    },
    {
      "id": "codex-skill-lifecycle-guards",
      "title": "codex runtime skills preserve lifecycle guards",
      "kind": "artifact_check",
      "objective": "Ensure Codex runtime artifacts keep startup and closeout guard commands in the shipped skill bodies.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../skills-codex/rpi/SKILL.md", "value": "ao codex ensure-start 2>/dev/null || true"},
        {"type": "artifact_contains", "target": "../../skills-codex/crank/SKILL.md", "value": "ao codex ensure-start 2>/dev/null || true"},
        {"type": "artifact_contains", "target": "../../skills-codex/status/SKILL.md", "value": "ao codex ensure-start 2>/dev/null || true"},
        {"type": "artifact_contains", "target": "../../skills-codex/recover/SKILL.md", "value": "ao codex ensure-start 2>/dev/null || true"},
        {"type": "artifact_contains", "target": "../../skills-codex/validation/SKILL.md", "value": "ao codex ensure-stop --auto-extract 2>/dev/null || true"}
      ],
      "dimensions": ["process_adherence", "runtime_compatibility", "safety"],
      "critical": true
    }
  ]
}
