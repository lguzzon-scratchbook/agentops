{
  "schema_version": 1,
  "id": "agentops-core.retrieval-quality-gates",
  "name": "AgentOps Retrieval Quality Gates Canary",
  "description": "Offline public canary for real-corpus retrieval quality, flywheel gate thresholds, Dream retrieval determinism, and retrieval quality ratchet wiring.",
  "domain": "retrieval",
  "visibility": "public_canary",
  "tier": "deterministic",
  "owners": ["agentops"],
  "tags": ["canary", "offline", "retrieval", "knowledge", "flywheel", "dream"],
  "allowed_runtimes": ["shell", "static"],
  "environment": {
    "offline_required": true,
    "network": "forbidden",
    "scrub_env_prefixes": ["AGENTOPS_RPI_RUNTIME", "ANTHROPIC_", "OPENAI_"],
    "timeout_seconds": 120
  },
  "fixtures": [
    {
      "path": "fixtures/retrieval-quality-smoke.sh",
      "purpose": "Behavioral retrieval smoke covering real-corpus benchmark tests, flywheel gate threshold tests, and deterministic live-corpus CLI JSON.",
      "required": true
    }
  ],
  "scoring": {
    "aggregate_threshold": 1,
    "dimensions": [
      {"name": "correctness", "weight": 2, "threshold": 1, "critical": true},
      {"name": "learning_closure", "weight": 2, "threshold": 1, "critical": true},
      {"name": "process_adherence", "weight": 1, "threshold": 1},
      {"name": "artifact_quality", "weight": 1, "threshold": 1},
      {"name": "runtime_compatibility", "weight": 1, "threshold": 1}
    ]
  },
  "baseline_policy": {"mode": "none"},
  "cases": [
    {
      "id": "retrieval-quality-smoke",
      "title": "real-corpus retrieval and flywheel gate smoke passes",
      "kind": "command",
      "objective": "Keep real-corpus train/holdout retrieval benchmark coverage, flywheel gate threshold behavior, and deterministic live-corpus CLI results passing.",
      "runtime": "shell",
      "timeout_seconds": 120,
      "inputs": {
        "cwd": "../..",
        "shell": "bash evals/agentops-core/fixtures/retrieval-quality-smoke.sh"
      },
      "expectations": [
        {"type": "exit_code", "value": 0},
        {"type": "stdout_contains", "value": "retrieval quality smoke passed"}
      ],
      "dimensions": ["correctness", "learning_closure", "runtime_compatibility"],
      "critical": true
    },
    {
      "id": "retrieval-dream-determinism-contract",
      "title": "Dream retrieval benchmark determinism remains documented",
      "kind": "artifact_check",
      "objective": "Keep Dream's MEASURE stage tied to deterministic retrieval-bench semantics.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../docs/contracts/dream-run-contract.md", "value": "ao retrieval-bench --live --json"},
        {"type": "artifact_contains", "target": "../../docs/contracts/dream-run-contract.md", "value": "deterministic by construction"},
        {"type": "artifact_contains", "target": "../../docs/contracts/dream-run-contract.md", "value": "stable sort by `CompositeScore`"},
        {"type": "artifact_contains", "target": "../../docs/contracts/dream-run-contract.md", "value": "no RNG to seed"}
      ],
      "dimensions": ["process_adherence", "learning_closure", "artifact_quality"],
      "critical": true
    },
    {
      "id": "retrieval-ratchet-wiring",
      "title": "retrieval quality ratchet keeps thresholds and fallback eval set",
      "kind": "artifact_check",
      "objective": "Keep the standalone retrieval quality ratchet wired to any-relevant@K, strictness thresholds, and a deterministic fallback manifest.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../scripts/check-retrieval-quality-ratchet.sh", "value": "DEFAULT_FALLBACK_MANIFEST=\"cli/cmd/ao/testdata/retrieval-bench/eval-queries.json\""},
        {"type": "artifact_contains", "target": "../../scripts/check-retrieval-quality-ratchet.sh", "value": "AGENTOPS_RETRIEVAL_RATCHET_MIN_ANY_RELEVANT"},
        {"type": "artifact_contains", "target": "../../scripts/check-retrieval-quality-ratchet.sh", "value": "any_relevant_at_k"},
        {"type": "artifact_contains", "target": "../../scripts/check-retrieval-quality-ratchet.sh", "value": "STRICT_TURNS"},
        {"type": "artifact_contains", "target": "../../scripts/check-retrieval-quality-ratchet.sh", "value": "WARN retrieval quality ratchet"}
      ],
      "dimensions": ["process_adherence", "artifact_quality", "learning_closure"]
    },
    {
      "id": "retrieval-real-corpus-fixtures",
      "title": "real-corpus retrieval fixtures preserve holdout labels",
      "kind": "artifact_check",
      "objective": "Keep the live retrieval fixture corpus large enough and explicitly labeled for holdout quality checks.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../cli/cmd/ao/testdata/retrieval-bench-live/benchmark.json", "value": "\"split\": \"holdout\""},
        {"type": "artifact_contains", "target": "../../cli/cmd/ao/testdata/retrieval-bench-live/benchmark.json", "value": "\"best_id\""},
        {"type": "artifact_contains", "target": "../../cli/cmd/ao/testdata/retrieval-bench-live/security-toolchain-gate.md", "value": "Security Toolchain Gate"},
        {"type": "artifact_contains", "target": "../../cli/cmd/ao/testdata/retrieval-bench-live/architecture-surface-contract.md", "value": "Architecture Surface Contract"}
      ],
      "dimensions": ["artifact_quality", "learning_closure"]
    }
  ]
}
