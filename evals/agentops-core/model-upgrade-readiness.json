{
  "schema_version": 1,
  "id": "agentops-core.model-upgrade-readiness",
  "name": "AgentOps Model Upgrade Readiness Canary",
  "description": "Offline public canary for model-upgrade baseline comparison, promotion metadata, and runtime-regression guardrails.",
  "domain": "mixed",
  "visibility": "public_canary",
  "tier": "deterministic",
  "owners": ["agentops"],
  "tags": ["canary", "offline", "model-upgrade", "baseline", "regression"],
  "allowed_runtimes": ["shell", "static"],
  "environment": {
    "offline_required": true,
    "network": "forbidden",
    "scrub_env_prefixes": ["AGENTOPS_RPI_RUNTIME", "ANTHROPIC_", "OPENAI_"],
    "timeout_seconds": 120
  },
  "fixtures": [
    {
      "path": "fixtures/model-upgrade-regression-smoke.sh",
      "purpose": "Synthetic baseline-vs-candidate regression smoke used to prove model-upgrade comparisons fail on worse behavior.",
      "required": true
    }
  ],
  "scoring": {
    "aggregate_threshold": 1,
    "dimensions": [
      {"name": "correctness", "weight": 2, "threshold": 1, "critical": true},
      {"name": "runtime_compatibility", "weight": 2, "threshold": 1, "critical": true},
      {"name": "learning_closure", "weight": 1, "threshold": 1},
      {"name": "process_adherence", "weight": 1, "threshold": 1},
      {"name": "artifact_quality", "weight": 1, "threshold": 1}
    ]
  },
  "baseline_policy": {"mode": "none"},
  "cases": [
    {
      "id": "synthetic-model-regression-detected",
      "title": "synthetic model candidate regression is detected",
      "kind": "command",
      "objective": "Prove a candidate run that scores worse than a baseline is classified as a regression with a negative aggregate delta and dimension regression evidence.",
      "runtime": "shell",
      "timeout_seconds": 180,
      "inputs": {
        "cwd": "../..",
        "shell": "bash evals/agentops-core/fixtures/model-upgrade-regression-smoke.sh"
      },
      "expectations": [
        {"type": "exit_code", "value": 0},
        {"type": "stdout_contains", "value": "model-upgrade regression detection passed"}
      ],
      "dimensions": ["correctness", "runtime_compatibility", "learning_closure"],
      "critical": true
    },
    {
      "id": "eval-baseline-command-tests",
      "title": "eval compare baseline and scorecard focused tests pass",
      "kind": "command",
      "objective": "Keep baseline promotion, candidate-vs-baseline comparison, zero-delta serialization, and scorecard regression/improvement behavior covered by Go tests.",
      "runtime": "shell",
      "inputs": {
        "cwd": "../../cli",
        "shell": "env -u AGENTOPS_RPI_RUNTIME go test -timeout=120s ./cmd/ao ./internal/eval -run 'TestEvalCompareCommandJSON|TestEvalCompareCommandJSONIncludesZeroAggregateDelta|TestEvalBaselineCommandJSON|TestEvalScorecardCommandJSON|TestCompareRunsMarksRegression|TestPromoteBaselineWritesRunRecord|TestBuildScorecardBaselineDeltaRegressionImprovement'"
      },
      "expectations": [
        {"type": "exit_code", "value": 0},
        {"type": "stdout_contains", "value": "ok  \tgithub.com/boshu2/agentops/cli/cmd/ao"},
        {"type": "stdout_contains", "value": "ok  \tgithub.com/boshu2/agentops/cli/internal/eval"}
      ],
      "dimensions": ["correctness", "learning_closure", "artifact_quality"],
      "critical": true
    },
    {
      "id": "model-upgrade-schema-contract",
      "title": "eval suite schema preserves model-upgrade gate metadata",
      "kind": "artifact_check",
      "objective": "Ensure eval suites can declare model-upgrade blocking gates and promotion requirements that prevent unsafe baseline promotion.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../schemas/eval-suite.v1.schema.json", "value": "\"model-upgrade\""},
        {"type": "artifact_contains", "target": "../../schemas/eval-suite.v1.schema.json", "value": "\"no_runtime_compatibility_regression\""},
        {"type": "artifact_contains", "target": "../../schemas/eval-suite.v1.schema.json", "value": "\"private_holdouts_reviewed\""},
        {"type": "artifact_contains", "target": "../../schemas/eval-suite.v1.schema.json", "value": "\"human_rationale\""}
      ],
      "dimensions": ["runtime_compatibility", "process_adherence", "artifact_quality"],
      "critical": true
    },
    {
      "id": "model-upgrade-doc-contract",
      "title": "eval environment contract documents model-upgrade comparison rules",
      "kind": "artifact_check",
      "objective": "Keep the operator-facing eval contract tied to model-upgrade use, private holdouts, baseline promotion, and better/worse verdict rules.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "model-upgrade"},
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "candidate-vs-baseline score comparison"},
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "Private holdouts"},
        {"type": "artifact_contains", "target": "../../docs/contracts/eval-environment.md", "value": "A candidate is better only when it preserves critical cases"}
      ],
      "dimensions": ["process_adherence", "learning_closure", "artifact_quality"]
    },
    {
      "id": "baseline-runner-rationale-required",
      "title": "baseline promotion requires rationale in eval runner",
      "kind": "artifact_check",
      "objective": "Ensure promoted baselines are intentional and carry rationale before being used to judge future model changes.",
      "expectations": [
        {"type": "artifact_contains", "target": "../../scripts/eval-agentops.sh", "value": "--promote-baseline requires --rationale"},
        {"type": "artifact_contains", "target": "../../scripts/eval-agentops.sh", "value": "baseline compare command failed"},
        {"type": "artifact_contains", "target": "../../scripts/eval-agentops.sh", "value": "regressed against baseline"}
      ],
      "dimensions": ["learning_closure", "process_adherence"]
    }
  ]
}
