{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Skill Frontmatter",
  "description": "Schema for AgentOps SKILL.md YAML frontmatter",
  "practices": ["design-by-contract", "code-complete"],
  "type": "object",
  "required": ["name", "description", "skill_api_version"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "skill_api_version": { "type": "integer", "const": 1 },
    "metadata": {
      "type": "object",
      "properties": {
        "tier": { "type": "string", "enum": ["judgment", "execution", "library", "session", "product", "contribute", "meta", "background", "orchestration", "cross-vendor", "knowledge"] },
        "dependencies": { "type": "array" },
        "internal": { "type": "boolean" },
        "version": { "type": "string" },
        "author": { "type": "string" },
        "triggers": { "type": "array", "items": { "type": "string" } },
        "replaces": { "type": "string" },
        "stability": { "type": "string", "enum": ["experimental", "stable"], "default": "stable" }
      }
    },
    "user-invocable": { "type": "boolean" },
    "context": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "window": { "type": "string", "enum": ["isolated", "fork", "inherit"] },
            "sections": {
              "type": "object",
              "properties": {
                "include": { "type": "array", "items": { "type": "string" } },
                "exclude": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "intent": {
              "type": "object",
              "properties": {
                "mode": { "type": "string", "enum": ["questions", "task", "none"] }
              },
              "additionalProperties": false
            },
            "intel_scope": { "type": "string", "enum": ["topic", "full", "none"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "allowed-tools": {
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        { "type": "string" }
      ]
    },
    "license": { "type": "string" },
    "compatibility": { "type": "string" },
    "model": { "type": "string", "description": "Preferred model for skill execution (e.g., haiku, sonnet)" },
    "output_contract": { "type": "string", "description": "Path to JSON Schema file defining this skill's structured output format (e.g., skills/council/schemas/verdict.json)" },
    "practices": {
      "type": "array",
      "description": "Practice slugs from PRACTICE.md that this primitive embodies. Validated by scripts/validate-practice-citations.sh.",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "hexagonal_role": {
      "type": "string",
      "description": "DDD/hexagonal role of this skill (frontmatter v2 backfill).",
      "enum": ["domain", "driving-adapter", "driven-adapter", "supporting", "generic"]
    },
    "consumes": {
      "type": "array",
      "description": "Artifact-kinds or skill slugs this skill consumes (frontmatter v2 backfill).",
      "items": { "type": "string" }
    },
    "produces": {
      "type": "array",
      "description": "Artifact-kinds this skill produces (frontmatter v2 backfill).",
      "items": { "type": "string" }
    },
    "context_rel": {
      "type": "array",
      "description": "Context-map relationships to other bounded contexts (frontmatter v2 backfill).",
      "items": {
        "type": "object",
        "required": ["kind", "with"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["shared-kernel", "customer-of", "supplier-to", "conformist-to", "acl-wraps", "separate-ways", "partnership"]
          },
          "with": { "type": "string", "description": "skill slug" }
        }
      }
    }
  },
  "additionalProperties": false
}
