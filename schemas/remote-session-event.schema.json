{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/remote-session-event.schema.json",
  "title": "AgentOps Remote Session Event v1",
  "description": "Append-only event shape for AgentOps remote sessions and idempotent command delivery.",
  "practices": ["event-sourcing-cqrs", "distributed-tracing"],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "occurred_at",
    "event_type",
    "session_id",
    "provider",
    "target",
    "event_cursor",
    "terminal_status",
    "command_id",
    "idempotency_key",
    "artifact_refs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "session_recorded",
        "session_started",
        "command_recorded",
        "command_delivery_attempted",
        "command_accepted",
        "command_rejected",
        "command_delivery_unknown",
        "event_cursor_advanced",
        "transcript_ref",
        "artifact_ref",
        "terminal_state"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_session_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "provider": {
      "type": "string",
      "enum": ["gascity"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "city"],
      "properties": {
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "city": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "oneOf": [
            { "type": "null" },
            { "type": "string" }
          ]
        }
      }
    },
    "job_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "attempt_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "request_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "provider_request_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "event_cursor": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 },
        { "type": "integer", "minimum": 0 }
      ]
    },
    "terminal_status": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "enum": [
            "completed",
            "failed",
            "cancelled",
            "lost",
            "provider_unreachable",
            "unknown"
          ]
        }
      ]
    },
    "command_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "idempotency_key": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "command_status": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "enum": [
            "recorded",
            "delivery_attempted",
            "accepted",
            "rejected",
            "delivery_unknown",
            "superseded"
          ]
        }
      ]
    },
    "transcript_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "message": {
      "type": "string"
    },
    "redacted_payload_ref": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    }
  }
}
