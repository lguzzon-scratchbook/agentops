{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/codex-marketplace.v1.schema.json",
  "title": "AgentOps Codex Marketplace Manifest v1",
  "$comment": "practices: [microservices, team-topologies]",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "plugins"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["displayName"],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "path"],
            "properties": {
              "source": {
                "const": "local"
              },
              "path": {
                "type": "string",
                "pattern": "^\\./"
              }
            }
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["installation", "authentication"],
            "properties": {
              "installation": {
                "type": "string",
                "enum": ["NOT_AVAILABLE", "AVAILABLE", "INSTALLED_BY_DEFAULT"]
              },
              "authentication": {
                "type": "string",
                "enum": ["ON_INSTALL", "ON_USE"]
              },
              "products": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "category": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
