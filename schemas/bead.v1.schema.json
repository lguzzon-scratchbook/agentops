{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/bead.v1.schema.json",
  "title": "Bead",
  "description": "A single unit of work within a quest",
  "type": "object",
  "required": ["bead_id", "quest_id", "title", "description", "status", "dependencies", "created_at", "schema_version"],
  "properties": {
    "bead_id": {
      "type": "string",
      "pattern": "^[0-9A-Za-z]{26}$",
      "description": "ULID identifier"
    },
    "quest_id": {
      "type": "string",
      "pattern": "^[0-9A-Za-z]{26}$",
      "description": "Parent quest ULID"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["unclaimed", "claimed", "done", "failed"]
    },
    "claimed_by": {
      "type": ["string", "null"],
      "description": "Agent session ID that claimed this bead"
    },
    "claimed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "verdict_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9A-Za-z]{26}$",
      "description": "Athena verdict ID that authorized completion"
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[0-9A-Za-z]{26}$"},
      "description": "Bead IDs that must complete before this one"
    },
    "output_path": {
      "type": ["string", "null"],
      "description": "Path to the work output"
    },
    "failure_reason": {
      "type": ["string", "null"],
      "description": "Reason for failure (set by apollo fail command)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    }
  },
  "additionalProperties": false
}
