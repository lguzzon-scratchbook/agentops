{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/boshu2/agentops/schemas/watch-event.v1.schema.json",
  "title": "AgentOps Watch Event v1",
  "description": "Append-only event line emitted to .agents/watch/events.jsonl for ao watch replay and follow modes.",
  "practices": ["event-sourcing-cqrs", "distributed-tracing"],
  "type": "object",
  "additionalProperties": true,
  "required": ["ts", "event", "worker_id"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp for the event."
    },
    "event": {
      "type": "string",
      "enum": [
        "wave.started",
        "wave.completed",
        "worker.spawned",
        "worker.started",
        "worker.tool_call",
        "worker.completed",
        "worker.failed",
        "validation.started",
        "validation.completed",
        "epic.closed"
      ]
    },
    "wave": {
      "type": "integer",
      "minimum": 0
    },
    "epic_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "files_claimed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "parent_event": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
